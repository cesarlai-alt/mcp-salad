      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@benborla29/mcp-server-mysql"
      ],
      "env_required": [
        {
          "name": "MYSQL_HOST",
          "description": "MySQL server hostname (e.g. localhost or 127.0.0.1)"
        },
        {
          "name": "MYSQL_USER",
          "description": "MySQL username"
        },
        {
          "name": "MYSQL_PASS",
          "description": "MySQL password"
        },
        {
          "name": "MYSQL_DB",
          "description": "Default database name to connect to"
        }
      ]
    },
    "claude_config": "{\n  \"command\": \"npx\",\n  \"args\": [\"-y\", \"@benborla29/mcp-server-mysql\"],\n  \"env\": {\n    \"MYSQL_HOST\": \"127.0.0.1\",\n    \"MYSQL_USER\": \"root\",\n    \"MYSQL_PASS\": \"YOUR_PASSWORD\",\n    \"MYSQL_DB\": \"your_database\"\n  }\n}\n"
