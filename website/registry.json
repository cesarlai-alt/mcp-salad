          "url": "https://github.com/settings/tokens"
        }
      ]
    },
    "claude_config": "{\n  \"command\": \"docker\",\n  \"args\": [\"run\", \"-i\", \"--rm\", \"-e\", \"GITHUB_PERSONAL_ACCESS_TOKEN\", \"ghcr.io/github/github-mcp-server\"],\n  \"env\": {\"GITHUB_PERSONAL_ACCESS_TOKEN\": \"YOUR_TOKEN_HERE\"}\n}\n"
